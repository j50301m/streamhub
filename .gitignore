# Rust
/target/
**/*.rs.bk

# Dependencies
Cargo.lock

# Terraform
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.backup
**/terraform.tfvars
**/*.auto.tfvars

# Environment
.env
.env.*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Worktrees (subagent working directories)
