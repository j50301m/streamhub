# Database
DATABASE_URL=postgres://streamhub:streamhub@postgres:5432/streamhub

# API Server
HOST=0.0.0.0
PORT=8080
JWT_SECRET=dev-secret-change-in-production
MEDIAMTX_URL=http://mediamtx:9997
RECORDINGS_PATH=/recordings

# GCS Storage
STORAGE_ENABLED=true
GCS_BUCKET=streamhub-recordings-dev
GCS_ENDPOINT=http://fake-gcs:4443
GCS_CREDENTIALS_PATH=

# Transcoder (disabled for local dev)
TRANSCODER_ENABLED=false
TRANSCODER_PROJECT_ID=
TRANSCODER_LOCATION=asia-east1
PUBSUB_VERIFY_TOKEN=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
