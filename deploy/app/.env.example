# Database
DATABASE_URL=postgres://streamhub:streamhub@postgres:5432/streamhub

# API Server
HOST=0.0.0.0
PORT=8080
JWT_SECRET=dev-secret-change-in-production
RECORDINGS_PATH=/recordings

# Redis
REDIS_URL=redis://redis:6379

# GCS Storage
GCS_BUCKET=streamhub-recordings-dev
GCS_ENDPOINT=http://fake-gcs:4443
GCS_CREDENTIALS_PATH=

# Transcoder (disabled for local dev)
TRANSCODER_ENABLED=false
TRANSCODER_PROJECT_ID=
TRANSCODER_LOCATION=asia-east1
PUBSUB_VERIFY_TOKEN=

# Thumbnails
THUMBNAILS_PATH=/thumbnails
THUMBNAIL_CAPTURE_INTERVAL_SECS=60

# MediaMTX Instances (JSON array)
MEDIAMTX_INSTANCES=[{"name":"mtx-1","internal_api":"http://mtx-1:9997","public_whip":"http://localhost:8889","public_whep":"http://localhost:8889","public_hls":"http://localhost:8888"},{"name":"mtx-2","internal_api":"http://mtx-2:9997","public_whip":"http://localhost:8899","public_whep":"http://localhost:8899","public_hls":"http://localhost:8898"},{"name":"mtx-3","internal_api":"http://mtx-3:9997","public_whip":"http://localhost:8909","public_whep":"http://localhost:8909","public_hls":"http://localhost:8908"}]

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
