DATABASE_URL=postgres://streamhub:streamhub@postgres:5432/streamhub
REDIS_URL=redis://redis:6379
# MUST match deploy/app/.env JWT_SECRET — admin frontend sends the same JWT to both bo-api and api
JWT_SECRET=your-secret-here
BO_API_HOST=0.0.0.0
BO_API_PORT=8800
BO_API_CORS_ORIGINS=http://localhost:3000

# Observability (OTLP/gRPC endpoint pushed to Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317

# Rate Limiting
RATE_LIMIT_BO_GENERAL_LIMIT=60
RATE_LIMIT_BO_GENERAL_WINDOW=60
